---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title = 'William Ortiz | DevSecOps Engineer',
  description =
    'William Ortiz — DevSecOps Engineer specializing in secure CI/CD pipelines, cloud security, infrastructure automation, and building resilient systems.',
  canonical = 'https://williamortiz.dev/',
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="DevSecOps, DevOps, Security Engineer, Cloud Security, CI/CD, Kubernetes, Docker, Terraform, AWS, William Ortiz"
    />
    <meta name="author" content="William Ortiz" />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://williamortiz.dev/images/profile-photo.jpeg" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="William Ortiz Portfolio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://williamortiz.dev/images/profile-photo.jpeg" />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
