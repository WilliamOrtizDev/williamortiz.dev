---
import Icon from './Icon.astro';
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-inner">
      <p class="footer-copy">
        &copy; <span id="footer-year"></span> William Ortiz. Built with purpose.
      </p>

      <nav class="footer-links" aria-label="Legal">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </nav>

      <div class="footer-social" aria-label="Social media links">
        <a href="mailto:contact@williamortiz.dev" aria-label="Send email">
          <Icon name="mail" size={15} />
        </a>
        <a
          href="https://github.com/WilliamOrtizDev"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >
          <Icon name="github" size={15} />
        </a>
        <a
          href="https://www.linkedin.com/in/williamortizdev/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <Icon name="linkedin" size={15} />
        </a>
      </div>
    </div>
  </div>
</footer>

<!-- Back to top -->
<button
  class="back-to-top hidden"
  id="back-to-top"
  aria-label="Back to top"
>
  <Icon name="arrow-up" size={16} />
</button>

<script>
  document.getElementById('footer-year')!.textContent = String(new Date().getFullYear());

  document.getElementById('back-to-top')!.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
