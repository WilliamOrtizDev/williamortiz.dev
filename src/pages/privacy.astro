---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Privacy Policy | William Ortiz"
  description="Privacy Policy for williamortiz.dev — how your data is collected, used, and protected."
  canonical="https://williamortiz.dev/privacy"
  noindex={true}
>
  <Nav />

  <main id="main-content">
    <article class="page-content">
      <div class="container">
        <h1>Privacy Policy</h1>
        <p class="page-meta">Last updated: March 7, 2026</p>

        <section>
          <h2>Overview</h2>
          <p>
            This Privacy Policy describes how williamortiz.dev ("the Site") collects,
            uses, and protects your information when you visit and interact with the Site.
            Your privacy matters, and I am committed to handling your data responsibly.
          </p>
        </section>

        <section>
          <h2>Information Collected</h2>
          <h3>Contact Form</h3>
          <p>When you submit the contact form, the following information is collected:</p>
          <ul>
            <li><strong>Name</strong> — to address you in my response</li>
            <li><strong>Email address</strong> — to reply to your inquiry</li>
            <li><strong>Message content</strong> — to understand your inquiry</li>
          </ul>
          <p>
            This information is transmitted via{' '}
            <a href="https://resend.com" target="_blank" rel="noopener noreferrer">Resend</a>
            {' '}and delivered to my email inbox. It is not stored in a database, sold,
            or shared with third parties.
          </p>

          <h3>Automatically Collected Information</h3>
          <p>
            The Site may collect standard web server log data including your IP address,
            browser type, referring page, and pages visited. This data is collected by
            the hosting provider (
            <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">Cloudflare</a>
            ) and is used solely for site performance and security monitoring.
          </p>
        </section>

        <section>
          <h2>How Your Information Is Used</h2>
          <ul>
            <li>To respond to your contact form submissions</li>
            <li>To monitor and improve site performance and security</li>
            <li>To comply with legal obligations if required</li>
          </ul>
        </section>

        <section>
          <h2>Third-Party Services</h2>
          <p>The Site uses the following third-party services:</p>
          <ul>
            <li>
              <strong>Cloudflare Pages</strong> — hosting and serverless functions (
              <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
              )
            </li>
            <li>
              <strong>Resend</strong> — email delivery for the contact form (
              <a href="https://resend.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
              )
            </li>
            <li>
              <strong>Google Fonts</strong> — web fonts (
              <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
              )
            </li>
            <li>
              <strong>GitHub API</strong> — fetching public repository data (
              <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
              )
            </li>
          </ul>
        </section>

        <section>
          <h2>Cookies</h2>
          <p>
            This Site does not use cookies or tracking scripts. No analytics or
            advertising trackers are present.
          </p>
        </section>

        <section>
          <h2>Data Retention</h2>
          <p>
            Contact form submissions are retained in my email inbox only as long as
            necessary to respond to your inquiry. No long-term database storage of form
            data is maintained.
          </p>
        </section>

        <section>
          <h2>Your Rights</h2>
          <p>You have the right to:</p>
          <ul>
            <li>Request information about what data has been collected about you</li>
            <li>Request deletion of your data</li>
            <li>Withdraw consent for data processing</li>
          </ul>
          <p>
            To exercise these rights, contact me at{' '}
            <a href="mailto:contact@williamortiz.dev">contact@williamortiz.dev</a>.
          </p>
        </section>

        <section>
          <h2>Changes to This Policy</h2>
          <p>
            This policy may be updated from time to time. The "Last updated" date at the
            top of this page reflects the most recent revision. Continued use of the Site
            after changes constitutes acceptance of the updated policy.
          </p>
        </section>

        <section>
          <h2>Contact</h2>
          <p>
            If you have questions about this Privacy Policy, please reach out at{' '}
            <a href="mailto:contact@williamortiz.dev">contact@williamortiz.dev</a>.
          </p>
        </section>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<script>
  // Nav scroll effect for secondary pages (start scrolled)
  document.getElementById('navbar')?.classList.add('scrolled');
</script>
